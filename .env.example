# Supabase (database) — required
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Clerk (auth) — required, set in Vercel via Clerk integration or manually
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...

# Plaid API (bank connections)
# Get from https://dashboard.plaid.com/developers/keys
# Add redirect URI in Dashboard > API > Allowed redirect URIs: https://your-domain.com/connect
PLAID_CLIENT_ID=your_client_id
PLAID_PRODUCTION_SECRET=your_production_secret
PLAID_SANDBOX_SECRET=your_sandbox_secret
# Use "sandbox" for testing, "production" for live
PLAID_ENV=sandbox

# Optional: OpenAI for AI chat and semantic search
# OPENAI_API_KEY=sk-...

# Optional: PaddleOCR for receipt parsing (better accuracy than GPT-4o Vision)
# Option A: PaddleOCR AI Studio layout-parsing API (recommended)
# Get token from https://aistudio.baidu.com — requires OPENAI_API_KEY for text→JSON parsing
# PADDLEOCR_AI_STUDIO_TOKEN=your_token
# PADDLEOCR_AI_STUDIO_URL=https://b3xbb1f6zar0x9me.aistudio-app.com/layout-parsing
# Option B: Self-hosted — run scripts/paddleocr-receipt-api and set:
# PADDLEOCR_API_URL=http://localhost:8000

# App URL for Stripe redirects (success/cancel)
APP_URL=https://coconut-lemon.vercel.app

# Stripe (payment requests)
# Get from https://dashboard.stripe.com/apikeys — use sk_test_* for sandbox
STRIPE_SECRET_KEY=sk_test_...
# Webhook: create endpoint at https://dashboard.stripe.com/webhooks, select checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...
