{
  "name": "coconut",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "push": "git push origin main",
    "dev": "NODE_OPTIONS='--disable-warning=DEP0169' next dev -H 0.0.0.0",
    "dev:phone": "echo \"\\n📱 On your phone (same WiFi): http://$(ipconfig getifaddr en0 2>/dev/null || hostname -I 2>/dev/null | awk '{print $1}'):3000\\n\" && npm run dev",
    "build": "NODE_OPTIONS='--disable-warning=DEP0169' next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS='--disable-warning=DEP0169' vitest run",
    "test:watch": "NODE_OPTIONS='--disable-warning=DEP0169' vitest",
    "test:unit": "NODE_OPTIONS='--disable-warning=DEP0169' vitest run",
    "test:e2e": "NODE_OPTIONS='--disable-warning=DEP0169' playwright test",
    "test:bug-sweep": "NODE_OPTIONS='--disable-warning=DEP0169' playwright test -c e2e/bug-sweep.config.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.39.0",
    "@supabase/supabase-js": "^2.98.0",
    "googleapis": "^171.4.0",
    "jose": "^6.2.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.487.0",
    "motion": "^12.23.24",
    "next": "^16.1.6",
    "openai": "^4.73.0",
    "plaid": "^41.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-plaid-link": "^4.1.1",
    "recharts": "^2.15.2",
    "stripe": "^20.4.0"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.7",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  }
}
